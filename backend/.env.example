# ── Database (MongoDB) ────────────────────────────────────────────────────────
# For local: mongodb://localhost:27017/smartattend
# For MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/smartattend
DATABASE_URL="mongodb://localhost:27017/smartattend"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Frontend URL (for CORS) ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── AI Microservice ───────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
